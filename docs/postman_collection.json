                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api", "bookings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": \"{{serviceId}}\",\n  \"scheduledAt\": \"2026-08-01T10:00:00.000Z\",\n  \"address\": \"221B Baker Street\",\n  \"notes\": \"Please call before arriving\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.id) { pm.environment.set('bookingId', data.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "List My Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api", "bookings"] }
          }
        },
        {
          "name": "Get Booking By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "{{bookingId}}"] }
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel", "host": ["{{baseUrl}}"], "path": ["api", "bookings", "{{bookingId}}", "cancel"] }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment (Stripe PaymentIntent)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/payments/create", "host": ["{{baseUrl}}"], "path": ["api", "payments", "create"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.payment && data.payment.id) { pm.environment.set('paymentId', data.payment.id); }",
                  "if (data && data.payment && data.payment.transactionId) { pm.environment.set('stripePaymentIntentId', data.payment.transactionId); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Simulate Card Payment (Stripe test card, no frontend needed)",
          "request": {
            "method": "POST",
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{stripeSecretKey}}", "type": "string" },
                { "key": "password", "value": "", "type": "string" }
              ]
            },
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "url": {
              "raw": "https://api.stripe.com/v1/payment_intents/{{stripePaymentIntentId}}/confirm",
              "protocol": "https",
              "host": ["api", "stripe", "com"],
              "path": ["v1", "payment_intents", "{{stripePaymentIntentId}}", "confirm"]
            },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "payment_method", "value": "pm_card_visa", "description": "Stripe's built-in always-succeeds test card. Use pm_card_visa_chargeDeclined to test the failure path instead." },
                { "key": "automatic_payment_methods[allow_redirects]", "value": "never" }
              ]
            },
            "description": "Calls Stripe's API directly to confirm the PaymentIntent with a test card — this replaces what Stripe.js/Elements would normally do in a browser. Requires 'stripeSecretKey' to be set in the environment (your sk_test_... key). After this succeeds, Stripe sends a real payment_intent.succeeded webhook to whatever endpoint you've configured, which flips the payment to COMPLETED and the booking to PAID."
          }
        },
        {
          "name": "List My Payment History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/payments", "host": ["{{baseUrl}}"], "path": ["api", "payments"] }
          }
        },
        {
          "name": "Get Payment By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/payments/{{paymentId}}", "host": ["{{baseUrl}}"], "path": ["api", "payments", "{{paymentId}}"] }
          }
        },
        {
          "name": "Stripe Webhook (confirm) - for reference, sent by Stripe CLI/Dashboard",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Stripe-Signature", "value": "t=...,v1=... (generated by Stripe, do not set manually)" }
            ],
            "url": { "raw": "{{baseUrl}}/api/payments/confirm", "host": ["{{baseUrl}}"], "path": ["api", "payments", "confirm"] },
            "body": {
              "mode": "raw",
              "raw": "// This endpoint is called by Stripe (CLI `stripe listen` or the Dashboard), not manually from Postman, since it requires a valid Stripe signature."
            }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
