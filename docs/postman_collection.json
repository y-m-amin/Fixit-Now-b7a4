{
  "info": {
    "name": "FixItNow API",
    "description": "Backend API for FixItNow, a home services marketplace. Import the companion FixItNow Local environment alongside this collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register - Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Customer\",\n  \"email\": \"jane.customer@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"CUSTOMER\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.token) { pm.environment.set('token', data.token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Register - Technician",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tom Technician\",\n  \"email\": \"tom.tech@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"TECHNICIAN\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.token) { pm.environment.set('technicianToken', data.token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.customer@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.token) { pm.environment.set('token', data.token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@fixitnow.com\",\n  \"password\": \"Admin@12345\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.token) { pm.environment.set('adminToken', data.token); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api", "categories"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (Array.isArray(data) && data.length) { pm.environment.set('categoryId', data[0].id); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Technicians (Public)",
      "item": [
        {
          "name": "List Technicians",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/technicians?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "technicians"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "category", "value": "Plumbing", "disabled": true },
                { "key": "location", "value": "Dhaka", "disabled": true },
                { "key": "minRating", "value": "4", "disabled": true }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.technicians && data.technicians.length) { pm.environment.set('technicianProfileId', data.technicians[0].id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Technician By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/technicians/{{technicianProfileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "technicians", "{{technicianProfileId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Technician (Self-Management)",
      "item": [
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{technicianToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/technician/profile", "host": ["{{baseUrl}}"], "path": ["api", "technician", "profile"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"10 years of residential plumbing experience.\",\n  \"experienceYears\": 10,\n  \"hourlyRate\": 25,\n  \"skills\": [\"pipe repair\", \"leak detection\"],\n  \"location\": \"Dhaka\"\n}"
            }
          }
        },
        {
          "name": "Update My Availability",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{technicianToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/technician/availability", "host": ["{{baseUrl}}"], "path": ["api", "technician", "availability"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slots\": [\n    { \"dayOfWeek\": 1, \"startTime\": \"09:00\", \"endTime\": \"17:00\" },\n    { \"dayOfWeek\": 3, \"startTime\": \"09:00\", \"endTime\": \"17:00\" }\n  ]\n}"
            }
          }
        },
        {
          "name": "Create Service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{technicianToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/technician/services", "host": ["{{baseUrl}}"], "path": ["api", "technician", "services"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{categoryId}}\",\n  \"title\": \"Kitchen sink leak repair\",\n  \"description\": \"Fix leaking kitchen sink pipes\",\n  \"price\": 45,\n  \"priceType\": \"FIXED\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.id) { pm.environment.set('serviceId', data.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Update My Service",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{technicianToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/technician/services/{{serviceId}}", "host": ["{{baseUrl}}"], "path": ["api", "technician", "services", "{{serviceId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 50\n}"
            }
          }
        },
        {
          "name": "Delete My Service",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{technicianToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/technician/services/{{serviceId}}", "host": ["{{baseUrl}}"], "path": ["api", "technician", "services", "{{serviceId}}"] }
          }
        },
        {
          "name": "Get My Incoming Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{technicianToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/technician/bookings", "host": ["{{baseUrl}}"], "path": ["api", "technician", "bookings"] }
          }
        },
        {
          "name": "Update Booking Status (accept/decline/start/complete)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{technicianToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/technician/bookings/{{bookingId}}", "host": ["{{baseUrl}}"], "path": ["api", "technician", "bookings", "{{bookingId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACCEPTED\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "List Services",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/services?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "services"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "category", "value": "Plumbing", "disabled": true },
                { "key": "maxPrice", "value": "100", "disabled": true }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
