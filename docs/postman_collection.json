            ],
            "url": { "raw": "{{baseUrl}}/api/admin/categories", "host": ["{{baseUrl}}"], "path": ["api", "admin", "categories"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electrical\",\n  \"description\": \"Wiring, fixtures, electrical repairs\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data && data.id) { pm.environment.set('categoryId', data.id); }"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
